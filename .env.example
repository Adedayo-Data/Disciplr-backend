# ─────────────────────────────────────────────────────────────────────────────
# Disciplr Backend — Environment Variables Reference
#
# Copy this file to .env and fill in real values.
# Lines beginning with "#" are comments and are ignored at runtime.
# NEVER commit your actual .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────

# Runtime environment. One of: development | production | test
NODE_ENV=development

# TCP port the HTTP server listens on (positive integer, default: 3000)
PORT=3000

# Logical service name included in structured log output
SERVICE_NAME=disciplr-backend

# PostgreSQL connection URL (required).
# Must start with postgres:// or postgresql://
DATABASE_URL=postgres://postgres:postgres@localhost:5432/disciplr

# ── CORS ──────────────────────────────────────────────────────────────────────

# Allowed cross-origin request origins (comma-separated http:// or https:// URLs).
# Production: set this explicitly — omitting it blocks ALL cross-origin requests.
# Development / test: defaults to http://localhost:3000 when unset.
# Use CORS_ORIGINS=* only if you intentionally want to allow every origin (not recommended).
# Example (multiple origins): CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=https://app.example.com

# ── Auth / Secrets ────────────────────────────────────────────────────────────

# General-purpose JWT signing secret (minimum 16 characters).
# MUST be changed from the default in production.
JWT_SECRET=change-me-in-production

# Access-token signing secret (minimum 16 characters).
JWT_ACCESS_SECRET=fallback-access-secret

# Refresh-token signing secret (minimum 16 characters).
JWT_REFRESH_SECRET=fallback-refresh-secret

# Access token lifetime — duration string: <number><unit> where unit is s/m/h/d.
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token lifetime.
JWT_REFRESH_EXPIRES_IN=7d

# Secret used to sign file-download tokens (minimum 16 characters).
# MUST be changed from the default in production.
DOWNLOAD_SECRET=change-me-in-production

# ── Horizon / Stellar ─────────────────────────────────────────────────────────

# Stellar Horizon API endpoint (required when the Horizon listener is active).
# Must be a valid http:// or https:// URL.
HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban contract address(es) to monitor (comma-separated; required with listener).
CONTRACT_ADDRESS=CDISCIPLR1234567890ABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890

# Starting ledger sequence number (non-negative integer, default: 0 = latest).
START_LEDGER=1000000

# Maximum number of retry attempts for transient Horizon errors (default: 3).
RETRY_MAX_ATTEMPTS=3

# Initial retry back-off delay in milliseconds (default: 100).
RETRY_BACKOFF_MS=100

# Graceful-shutdown window for the Horizon listener in milliseconds (default: 30000).
HORIZON_SHUTDOWN_TIMEOUT_MS=30000

# Ledger lag count before an alert is emitted (non-negative integer, default: 10).
HORIZON_LAG_THRESHOLD=10

# ── Soroban ───────────────────────────────────────────────────────────────────

# SOROBAN_CONTRACT_ID=
# SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# SOROBAN_SOURCE_ACCOUNT=
# STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Job System ────────────────────────────────────────────────────────────────

# Number of concurrent job workers (positive integer, default: 2).
JOB_WORKER_CONCURRENCY=2

# Interval between job-queue polls in milliseconds (positive integer, default: 250).
JOB_QUEUE_POLL_INTERVAL_MS=250

# Maximum number of completed/failed jobs to retain in history (default: 50).
JOB_HISTORY_LIMIT=50

# Set to "true" to enable the background job scheduler.
# ENABLE_JOB_SCHEDULER=true

# ── ETL ───────────────────────────────────────────────────────────────────────

# How often the ETL worker runs in minutes (positive integer, default: 5).
ETL_INTERVAL_MINUTES=5

# Set to "true" to enable the ETL worker.
# ENABLE_ETL_WORKER=true

# Optional date range for a historical backfill (ISO 8601 strings).
# ETL_BACKFILL_FROM=2024-01-01T00:00:00Z
# ETL_BACKFILL_TO=2024-12-31T23:59:59Z

# ── Security Thresholds ───────────────────────────────────────────────────────

# General rate-limit window in milliseconds (default: 60000 = 1 minute).
SECURITY_RATE_LIMIT_WINDOW_MS=60000

# Maximum requests per IP within the rate-limit window (default: 120).
SECURITY_RATE_LIMIT_MAX_REQUESTS=120

# Sliding window for suspicious-activity detection in milliseconds (default: 300000 = 5 min).
SECURITY_SUSPICIOUS_WINDOW_MS=300000

# Number of 404 responses before an IP is flagged as suspicious (default: 20).
SECURITY_SUSPICIOUS_404_THRESHOLD=20

# Number of distinct paths before an IP is flagged (default: 12).
SECURITY_SUSPICIOUS_DISTINCT_PATH_THRESHOLD=12

# Number of 400 responses before an IP is flagged (default: 30).
SECURITY_SUSPICIOUS_BAD_REQUEST_THRESHOLD=30

# Total request volume threshold for high-traffic flagging (default: 300).
SECURITY_SUSPICIOUS_HIGH_VOLUME_THRESHOLD=300

# Sliding window for failed-login tracking in milliseconds (default: 900000 = 15 min).
SECURITY_FAILED_LOGIN_WINDOW_MS=900000

# Number of failed logins within the window before a burst alert fires (default: 5).
SECURITY_FAILED_LOGIN_BURST_THRESHOLD=5

# Minimum time between repeated security alerts for the same IP in milliseconds (default: 300000).
SECURITY_ALERT_COOLDOWN_MS=300000

# ── Schedulers ────────────────────────────────────────────────────────────────

# How often deadline checks run in milliseconds (default: 60000 = 1 minute).
DEADLINE_CHECK_INTERVAL_MS=60000

# How often analytics are recomputed in milliseconds (default: 300000 = 5 minutes).
ANALYTICS_RECOMPUTE_INTERVAL_MS=300000
