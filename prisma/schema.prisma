generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  VERIFIER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum VaultStatus {
  DRAFT
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  role          UserRole       @default(USER)
  status        UserStatus     @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lastLoginAt   DateTime?
  deletedAt     DateTime?
  vaults        Vault[]
  refreshTokens RefreshToken[]
  transactions  Transaction[]

  @@index([deletedAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
}

model Vault {
  id                 String      @id @default(uuid())
  creatorId          String      @map("creator_id")
  creator            User        @relation(fields: [creatorId], references: [id])
  amount             String
  startDate          DateTime    @default(now()) @map("start_date")
  endDate            DateTime    @map("end_date")
  verifier           String
  successDestination String      @map("success_destination")
  failureDestination String      @map("failure_destination")
  status             VaultStatus @default(DRAFT)
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  transactions       Transaction[]

  @@index([creatorId])
  @@index([status])
  @@index([endDate])
  @@map("vaults")
}

enum TransactionType {
  creation
  validation
  release
  redirect
  cancel
}

model Transaction {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String          @map("user_id") @db.Uuid
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  vaultId          String          @map("vault_id")
  vault            Vault           @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  txHash           String          @unique @map("tx_hash") @db.VarChar(64)
  type             TransactionType
  amount           Decimal         @db.Decimal(36, 7)
  assetCode        String?         @map("asset_code") @db.VarChar(12)
  fromAccount      String          @map("from_account") @db.VarChar(56)
  toAccount        String          @map("to_account") @db.VarChar(56)
  memo             String?
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz
  stellarLedger    Int             @map("stellar_ledger")
  stellarTimestamp DateTime        @map("stellar_timestamp") @db.Timestamptz
  explorerUrl      String          @map("explorer_url") @db.VarChar(255)

  @@index([userId], name: "idx_transactions_user_id")
  @@index([vaultId], name: "idx_transactions_vault_id")
  @@index([type], name: "idx_transactions_type")
  @@index([createdAt], name: "idx_transactions_created_at")
  @@index([stellarLedger], name: "idx_transactions_stellar_ledger")
  @@index([txHash], name: "idx_transactions_tx_hash")
  @@index([userId, vaultId, type, createdAt], name: "idx_transactions_user_vault_type_created")
  @@map("transactions")
}
